{
    "name": "eg-mohamed/laravel-ga4-events",
    "description": "A Laravel package to define and dispatch Google Analytics 4 (GA4) events.",
    "keywords": [
        "MohamedSaid",
        "laravel",
        "laravel-ga4-events"
    ],
    "homepage": "https://github.com/eg-mohamed/laravel-ga4-events",
    "license": "MIT",
    "authors": [
        {
            "name": "Mohamed Said",
            "email": "me@msaied.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.93",
        "illuminate/support": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "nunomaduro/collision": "^8.9.1",
        "orchestra/testbench": "^8.0||^9.0||^10.0||^11.0",
        "pestphp/pest": "^4.4.3",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "MohamedSaid\\LaravelGa4Events\\": "src/",
            "MohamedSaid\\LaravelGa4Events\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MohamedSaid\\LaravelGa4Events\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MohamedSaid\\LaravelGa4Events\\LaravelGa4EventsServiceProvider"
            ],
            "aliases": {
                "LaravelGa4Events": "MohamedSaid\\LaravelGa4Events\\Facades\\LaravelGa4Events"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
